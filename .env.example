# Payload CMS
PAYLOAD_SECRET=replace-with-a-strong-secret

# PostgreSQL (matches docker-compose.yml by default)
DATABASE_URL=postgresql://payload:payload_password@localhost:5432/payload

# Optional token for the /seed route
SEED_TOKEN=replace-with-a-seed-token

# Seed script admin password
SEED_ADMIN_PASSWORD=replace-with-a-local-admin-password
